      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{predictedBacteria=="yes" || conditionResult=="yes"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1ui8hmi" name="no" sourceRef="meetRegulationCondition" targetRef="discardTask">
