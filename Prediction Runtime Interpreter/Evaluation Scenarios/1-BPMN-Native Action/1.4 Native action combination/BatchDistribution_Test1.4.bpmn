  <bpmn:collaboration id="Collaboration_08a60ne">
    <bpmn:participant id="Participant_0vx8013" name="Drug Batch Handling" processRef="DrugBatches" />
  </bpmn:collaboration>
  <bpmn:process id="DrugBatches" name="DrugBatches" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1o2gmnt">
      <bpmn:lane id="Lane_05em9by" name="Laboratory Technician">
        <bpmn:flowNodeRef>labReadyMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>analysisTask</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_160mw34" name="Articulated Robot">
        <bpmn:flowNodeRef>meetRegulationCondition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discardTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>placeDistributionTak</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_19az0rf</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>endEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>storageTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0z2k1us</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_186k25r</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_1j1nyhg" name="Quality Technician">
        <bpmn:flowNodeRef>batchArrivalMsg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>manualInspectionTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>selectSampleTask</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:exclusiveGateway id="meetRegulationCondition" name="Meet Regulations?">
      <bpmn:extensionElements>
        <camunda:executionListener class="es.upv.pros.pvalderas.dsl.test.pharmacy.RegulationsCondition" event="start" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03t3gj2</bpmn:incoming>
      <bpmn:incoming>Flow_17r1l1h</bpmn:incoming>
      <bpmn:outgoing>Flow_09nczpm</bpmn:outgoing>
      <bpmn:outgoing>Flow_1ui8hmi</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="discardTask" name="Discard" camunda:class="es.upv.pros.pvalderas.bpcontroller.server.bpmn.BPMNServiceClass">
      <bpmn:incoming>Flow_1ui8hmi</bpmn:incoming>
      <bpmn:outgoing>Flow_00y9ly2</bpmn:outgoing>
    </bpmn:serviceTask>
