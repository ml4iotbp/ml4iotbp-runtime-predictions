      <bpmn:messageEventDefinition id="MessageEventDefinition_1ugqyl0" messageRef="Message_03dgk5f" />
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="labReadyMessage" name="Laboratory Ready">
